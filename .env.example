SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ...your-service-role-key

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-1
AWS_AMI_ID=ami-0c02fb55956c7d316
AWS_INSTANCE_TYPE=t3.medium
AWS_KEY_PAIR_NAME=
AWS_SECURITY_GROUP_ID=

BELLEQ_MASTER_IMAGE=sstprk/mnemo_master:latest
BELLEQ_CONTAINER_IMAGE=sstprk/mnemo_container:latest
INTERNAL_POLL_INTERVAL=15
INTERNAL_POLL_TIMEOUT=600
CORS_ORIGINS=http://localhost:3000,https://belleq.com,https://app.belleq.com

# Central embedding service (shared Ollama) — baked into masters at host launch.
EMBEDDING_OLLAMA_URL=
EMBEDDING_MODEL=nomic-embed-text

# Conversation fact-extraction. Set the Gemini key here ONCE — it is pushed to
# every context at provision time, so masters/containers never store it.
# (Free Gemini/AI-Studio tier may train on data — link billing for customer data.)
CONVERSATION_EXTRACTION_ENABLED=true
EXTRACTION_BACKEND=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# Only if EXTRACTION_BACKEND=anthropic:
# EXTRACTION_ANTHROPIC_API_KEY=
# EXTRACTION_MODEL=claude-haiku-4-5
